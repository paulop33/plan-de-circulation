{
    "name": "app/plan-de-circulation",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "6.4.*",
        "symfony/runtime": "6.4.*",
        "doctrine/dbal": "^3.8",
        "doctrine/doctrine-bundle": "^2.11",
        "nelmio/cors-bundle": "^2.4",
        "symfony/http-client": "6.4.*",
        "symfony/yaml": "6.4.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "platform": {
            "php": "8.2.30"
        }
    },
    "scripts": {
        "auto-scripts": {},
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "extra": {
        "symfony": {
            "allow-contrib": true
        }
    }
}
